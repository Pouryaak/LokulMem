{
  "name": "lokulmem",
  "version": "0.1.0",
  "description": "Browser-native LLM memory management library",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.mjs"
      },
      "require": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.cjs"
      }
    },
    "./worker": {
      "import": "./dist/worker.mjs",
      "require": "./dist/worker.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "dist/*.wasm",
    "dist/ort-wasm*.mjs",
    "dist/assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration:smoke": "playwright test tests/integration/ci-smoke.spec.ts",
    "eval:memory": "vitest run --config vitest.eval.config.ts",
    "eval:memory:A": "EVAL_GATE=A npm run eval:memory",
    "eval:memory:B": "EVAL_GATE=B npm run eval:memory",
    "eval:memory:C": "EVAL_GATE=C npm run eval:memory",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify:dist": "node tests/scripts/verify-dist.mjs",
    "verify:package": "npm run build && npm run verify:dist && npm pack --dry-run",
    "clean": "rm -rf dist",
    "ci": "biome ci . && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "happy-dom": "^20.7.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.40.0",
    "simple-git-hooks": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.79",
    "@huggingface/transformers": "^3.0.0",
    "dexie": "^4.3.0"
  }
}
